# App
PORT=8084
SECRET_KEY=changeme-secret
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Erstbenutzer (wird beim ersten Start angelegt, falls noch kein User existiert)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-admin-password

# Pfade (Host-Pfade fuer Volumes)
DATA_PATH=/home/user/home-warehouse/data
IMAGES_PATH=/home/user/home-warehouse/images

# API
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8084

# KI-Integration
# Die eigentliche Bilderkennung laeuft On-Device in der Android-App (kein Cloud-Call).
# Das Backend nimmt nur die von der App gelieferten KI-Metadaten entgegen.
# Siehe ANDROID_INTEGRATION.md fuer Details.
AI_PROVIDER=none
AI_API_KEY=changeme-key
AI_MODEL=on-device
